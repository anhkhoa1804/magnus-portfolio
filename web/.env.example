# Canonical site URL (used for robots/sitemap/rss absolute links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (Supabase PostgreSQL) - REQUIRED for user data persistence
# Get at: https://supabase.com → Create Project → Settings → Database
DATABASE_URL=
DIRECT_URL=

# Mapbox (REQUIRED for Wanderlust travel map)
# Get at: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# NextAuth.js - Authentication (REQUIRED for saving IELTS attempts)
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (at least one REQUIRED)
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: embed a Gradio app inside /lab/gradio
# AI Backend URL (FastAPI service for German news, predictions, etc.)
NEXT_PUBLIC_GRADIO_URL=http://localhost:8000

# Optional: enable email sending for /api/contact
# If these are missing, messages are accepted and logged only.
CONTACT_TO_EMAIL=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: Lab / BFF integrations
# Stocks (server-side). If missing, the stocks module returns mock data.
ALPHAVANTAGE_API_KEY=

# Optional: Discord presence (server-side via Lanyard)
# Used by /api/presence and the Lab Presence widget.
DISCORD_USER_ID=

# AI tools (server-side). If missing, AI routes return a helpful "not configured" response.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# HuggingFace AI Backend (for IELTS, speaking practice)
HUGGINGFACE_API_TOKEN=
AI_BACKEND_URL=https://anhkhoa1804-magnus-ai-backend.hf.space

# Upstash Redis - Queue for long-running tasks (optional but recommended)
# Get at: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Media (server-side). If missing, Unsplash route falls back to picsum.photos.
# Get at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Optional: CoinGecko (crypto prices)
# Get at: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# Optional: GitHub (activity widget)
# Get at: https://github.com/settings/tokens (needs repo, user scopes)
GITHUB_ACCESS_TOKEN=

# Optional: News / Weather / Spotify
# OpenWeather: https://openweathermap.org/api
OPENWEATHER_API_KEY=
NEXT_PUBLIC_WEATHER_UNIT=metric

# News API: https://newsapi.org/register
NEWSAPI_KEY=

# Spotify: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Optional: WakaTime (coding stats)
# Get at: https://wakatime.com/settings/api-key
WAKATIME_API_KEY=

# Optional: Crypto (not used yet)
COINGECKO_API_KEY=

# Footprints map (client-side public token)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: Content source
# Default: filesystem MDX under `apps/web/content/*`
# DB mode: run backend, seed/import MDX into Postgres, then set:
#   CONTENT_SOURCE=db
#   CONTENT_API_BASE_URL=http://localhost:3001
# Also used as the backend base for Dashboard signals (/api/dashboard).
CONTENT_SOURCE=fs
CONTENT_API_BASE_URL=http://localhost:3001
